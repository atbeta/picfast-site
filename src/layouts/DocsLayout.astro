---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  sidebar?: { label: string; href: string }[];
}

const { title, description, sidebar = [] } = Astro.props;
const currentPath = Astro.url.pathname;
const locale = currentPath.startsWith('/zh') ? 'zh' : 'en';
---

<BaseLayout title={`${title} — PicFast`} description={description}>
  <div class="docs-wrapper">
    <aside class="docs-sidebar">
      <div class="sidebar-inner">
        <p class="sidebar-heading">
          {locale === 'en' ? 'Getting Started' : '快速开始'}
        </p>
        <ul class="sidebar-list">
          <li><a href={locale === 'en' ? '/docs/getting-started' : '/zh/docs/getting-started'} class:list={[{ active: currentPath.endsWith('getting-started') }]}>
            {locale === 'en' ? 'Quick Start' : '快速开始'}
          </a></li>
          <li><a href={locale === 'en' ? '/docs/configuration' : '/zh/docs/configuration'} class:list={[{ active: currentPath.endsWith('configuration') }]}>
            {locale === 'en' ? 'Configuration' : '配置'}
          </a></li>
          <li><a href={locale === 'en' ? '/docs/oauth' : '/zh/docs/oauth'} class:list={[{ active: currentPath.endsWith('oauth') }]}>
            {locale === 'en' ? 'OAuth Login' : 'OAuth 登录'}
          </a></li>
        </ul>

        <p class="sidebar-heading">
          {locale === 'en' ? 'Theme' : '主题'}
        </p>
        <ul class="sidebar-list">
          <li><a href={locale === 'en' ? '/docs/custom-css' : '/zh/docs/custom-css'} class:list={[{ active: currentPath.endsWith('custom-css') }]}>
            {locale === 'en' ? 'Custom CSS' : '自定义 CSS'}
          </a></li>
        </ul>

        <p class="sidebar-heading">
          {locale === 'en' ? 'Guides' : '使用指南'}
        </p>
        <ul class="sidebar-list">
          <li><a href={locale === 'en' ? '/docs/upload' : '/zh/docs/upload'} class:list={[{ active: currentPath.endsWith('upload') }]}>
            {locale === 'en' ? 'Upload Images' : '上传图片'}
          </a></li>
          <li><a href={locale === 'en' ? '/docs/image-processing' : '/zh/docs/image-processing'} class:list={[{ active: currentPath.endsWith('image-processing') }]}>
            {locale === 'en' ? 'Image Processing' : '图片处理'}
          </a></li>
          <li><a href={locale === 'en' ? '/docs/storage' : '/zh/docs/storage'} class:list={[{ active: currentPath.endsWith('storage') }]}>
            {locale === 'en' ? 'Storage Backends' : '存储后端'}
          </a></li>
          <li><a href={locale === 'en' ? '/docs/moderation' : '/zh/docs/moderation'} class:list={[{ active: currentPath.endsWith('moderation') }]}>
            {locale === 'en' ? 'Content Moderation' : '内容审核'}
          </a></li>
        </ul>

        <p class="sidebar-heading">
          {locale === 'en' ? 'Integrations' : '集成'}
        </p>
        <ul class="sidebar-list">
          <li><a href={locale === 'en' ? '/docs/api' : '/zh/docs/api'} class:list={[{ active: currentPath.endsWith('api') }]}>
            {locale === 'en' ? 'API Reference' : 'API 参考'}
          </a></li>
          <li><a href={locale === 'en' ? '/docs/sharex' : '/zh/docs/sharex'} class:list={[{ active: currentPath.endsWith('sharex') }]}>
            {locale === 'en' ? 'ShareX Integration' : 'ShareX 集成'}
          </a></li>
          <li><a href={locale === 'en' ? '/docs/client-tools' : '/zh/docs/client-tools'} class:list={[{ active: currentPath.endsWith('client-tools') }]}>
            {locale === 'en' ? 'Client Tools' : '客户端工具'}
          </a></li>
          <li><a href={locale === 'en' ? '/docs/mcp' : '/zh/docs/mcp'} class:list={[{ active: currentPath.endsWith('mcp') }]}>
            {locale === 'en' ? 'MCP Integration' : 'MCP 集成'}
          </a></li>
          <li><a href={locale === 'en' ? '/docs/webhooks' : '/zh/docs/webhooks'} class:list={[{ active: currentPath.endsWith('webhooks') }]}>
            {locale === 'en' ? 'Webhooks' : 'Webhooks'}
          </a></li>
        </ul>

        <p class="sidebar-heading">
          {locale === 'en' ? 'Production' : '生产部署'}
        </p>
        <ul class="sidebar-list">
          <li><a href={locale === 'en' ? '/docs/deployment' : '/zh/docs/deployment'} class:list={[{ active: currentPath.endsWith('deployment') }]}>
            {locale === 'en' ? 'Deployment' : '部署'}
          </a></li>
          <li><a href={locale === 'en' ? '/docs/maintenance' : '/zh/docs/maintenance'} class:list={[{ active: currentPath.endsWith('maintenance') }]}>
            {locale === 'en' ? 'Backup & Maintenance' : '备份与维护'}
          </a></li>
          <li><a href={locale === 'en' ? '/docs/home-network' : '/zh/docs/home-network'} class:list={[{ active: currentPath.endsWith('home-network') }]}>
            {locale === 'en' ? 'Home Network & NAS' : '家庭网络 & NAS'}
          </a></li>
        </ul>
      </div>
    </aside>

    <article class="docs-content">
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .docs-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
    display: grid;
    grid-template-columns: 190px 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  @media (max-width: 860px) {
    .docs-wrapper {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .docs-sidebar {
      display: none;
    }
  }

  .docs-sidebar {
    position: sticky;
    top: 80px;
  }

  .sidebar-inner {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sidebar-heading {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-dim);
    padding: 1rem 0.5rem 0.375rem;
    margin-top: 0.25rem;
    border-top: 1px solid var(--border);
  }

  .sidebar-heading:first-child {
    border-top: none;
    padding-top: 0.25rem;
  }

  .sidebar-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .sidebar-list a {
    display: block;
    padding: 0.4375rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.84375rem;
    color: var(--text-muted);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    letter-spacing: -0.01em;
    position: relative;
    overflow: hidden;
  }
  
  .sidebar-list a::before {
    content: '';
    position: absolute;
    top: 0; left: 0; bottom: 0; right: 0;
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: -1;
  }

  .sidebar-list a:hover {
    color: var(--text);
    background: var(--bg-alt);
    transform: translateX(2px);
  }

  .sidebar-list a.active {
    color: var(--accent);
    font-weight: 600;
    transform: translateX(2px);
  }

  .sidebar-list a.active::before {
    opacity: 0.08;
  }

  .docs-content {
    min-width: 0;
  }

  .docs-content :global(h1) {
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.035em;
    margin-bottom: 1.25rem;
    line-height: 1.2;
    background: linear-gradient(135deg, var(--text) 0%, var(--text-muted) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .docs-content :global(h2),
  .docs-content :global(h3),
  .docs-content :global(h4) {
    scroll-margin-top: 80px; /* Account for fixed header */
  }

  .docs-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
  }

  .docs-content :global(h3) {
    font-size: 1.1875rem;
    font-weight: 650;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--text);
  }

  .docs-content :global(h4) {
    font-size: 1.0625rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .docs-content :global(p) {
    margin-bottom: 1.125rem;
    color: var(--text-muted);
    line-height: 1.75;
    font-size: 0.96875rem;
  }

  .docs-content :global(ul),
  .docs-content :global(ol) {
    margin-bottom: 1.125rem;
    padding-left: 1.5rem;
    color: var(--text-muted);
  }

  .docs-content :global(li::marker) {
    color: var(--text-dim);
  }

  .docs-content :global(li) {
    margin-bottom: 0.375rem;
    line-height: 1.7;
    font-size: 0.96875rem;
  }

  .docs-content :global(a) {
    color: var(--accent);
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }
  .docs-content :global(a:hover) {
    color: var(--accent-hover);
    text-decoration: underline;
  }

  .docs-content :global(blockquote) {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border-left: 3px solid var(--accent);
    background: var(--accent-subtle);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    color: var(--text);
  }

  .docs-content :global(blockquote p) {
    margin-bottom: 0;
  }

  .docs-content :global(blockquote p:not(:last-child)) {
    margin-bottom: 0.75rem;
  }

  .docs-content :global(.code-block) {
    margin: 1.5rem 0;
  }

  .docs-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
  }

  .docs-content :global(th),
  .docs-content :global(td) {
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .docs-content :global(th) {
    font-weight: 600;
    background: var(--bg-alt);
    position: sticky;
    top: 56px;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 0.75rem;
  }

  .docs-content :global(tbody tr:hover td) {
    background: var(--accent-subtle);
  }

  .docs-content :global(pre) {
    line-height: 1.7;
    box-shadow: var(--shadow-sm);
  }

  .docs-content :global(td code) {
    white-space: nowrap;
  }
</style>
