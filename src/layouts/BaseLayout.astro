---
interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const {
  title,
  description = 'PicFast — Self-hosted image hosting platform. Deploy in one command with Docker. Full admin panel, 6 storage backends, API-first with MCP AI integration and ShareX support.',
  lang = 'en',
} = Astro.props;

const currentPath = Astro.url.pathname;
const isDocs = currentPath.startsWith('/zh/docs') || currentPath.startsWith('/docs');
const locale = currentPath.startsWith('/zh') ? 'zh' : 'en';
const switchLocale = locale === 'en' ? '/zh' : '/';
const switchLocaleLabel = locale === 'en' ? '中文' : 'English';
const homeLink = locale === 'en' ? '/' : '/zh';
const docsLink = locale === 'en' ? '/docs/getting-started' : '/zh/docs/getting-started';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script is:inline>
      (function() {
        var t = localStorage.getItem('picfast-theme');
        if (t) document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href={homeLink} class="logo">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <rect width="28" height="28" rx="6" fill="var(--accent)"/>
            <path d="M7 14L11.5 18.5L17 10L21 16L24 13" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="8" cy="10" r="2" fill="white"/>
          </svg>
          <span class="logo-text">PicFast</span>
        </a>
        <nav class="nav-links">
          <a href={docsLink} class:list={["nav-link", { active: isDocs }]}>
            {locale === 'en' ? 'Docs' : '文档'}
          </a>
          <a href="https://github.com/atbeta/picfast" class="nav-link" target="_blank" rel="noopener">
            GitHub
          </a>
          <button id="theme-toggle" class="theme-btn" aria-label="Toggle theme">
            <svg class="icon-sun" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.75"/>
              <path d="M8 1v1.5M8 13.5V15M15 8h-1.5M2.5 8H1M12.95 3.05l-1.06 1.06M4.11 11.89l-1.06 1.06M12.95 12.95l-1.06-1.06M4.11 4.11L3.05 3.05" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <svg class="icon-moon" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M13 10.5A6 6 0 015.5 3 5 5 0 1013 10.5z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
            </svg>
          </button>
          <a href={switchLocale} class="nav-link lang-switch">
            {switchLocaleLabel}
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <a href={homeLink} class="logo">
            <svg width="20" height="20" viewBox="0 0 28 28" fill="none">
              <rect width="28" height="28" rx="6" fill="var(--accent)"/>
              <path d="M7 14L11.5 18.5L17 10L21 16L24 13" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="8" cy="10" r="2" fill="white"/>
            </svg>
            <span>PicFast</span>
          </a>
          <p class="footer-tagline">
            {locale === 'en'
              ? 'Self-hosted image hosting platform. One command to deploy.'
              : '自托管图床平台，一行命令即可部署。'}
          </p>
        </div>
        <div class="footer-links">
          <a href={docsLink}>
            {locale === 'en' ? 'Documentation' : '文档'}
          </a>
          <a href="https://github.com/atbeta/picfast" target="_blank" rel="noopener">GitHub</a>
          <a href={switchLocale}>{switchLocaleLabel}</a>
        </div>
        <p class="footer-copy">
          GNU GPL v3 · {new Date().getFullYear()}
        </p>
      </div>
    </footer>

    <script is:inline>
      (function() {
        var btn = document.getElementById('theme-toggle');
        var html = document.documentElement;

        function effectiveTheme() {
          var stored = localStorage.getItem('picfast-theme');
          if (stored === 'dark' || stored === 'light') return stored;
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }

        btn.addEventListener('click', function() {
          var next = effectiveTheme() === 'dark' ? 'light' : 'dark';
          html.setAttribute('data-theme', next);
          localStorage.setItem('picfast-theme', next);
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #ffffff;
    --bg-alt: #f7f8fa;
    --text: #111827;
    --text-muted: #6b7280;
    --border: #e5e7eb;
    --accent: #2563eb;
    --accent-hover: #1d4ed8;
    --code-bg: #f3f4f6;
    --code-text: #111827;
    --radius: 8px;
    --font-sans: 'Inter', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }

  :root[data-theme="dark"] {
    --bg: #0f1117;
    --bg-alt: #1a1d27;
    --text: #e5e7eb;
    --text-muted: #9ca3af;
    --border: #2d3140;
    --accent: #3b82f6;
    --accent-hover: #60a5fa;
    --code-bg: #1e2330;
    --code-text: #e5e7eb;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) {
      --bg: #0f1117;
      --bg-alt: #1a1d27;
      --text: #e5e7eb;
      --text-muted: #9ca3af;
      --border: #2d3140;
      --accent: #3b82f6;
      --accent-hover: #60a5fa;
      --code-bg: #1e2330;
      --code-text: #e5e7eb;
    }
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    -webkit-text-size-adjust: 100%;
  }

  body {
    font-family: var(--font-sans);
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }
  a:hover {
    color: var(--accent-hover);
  }

  img {
    max-width: 100%;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--code-bg);
    color: var(--code-text);
    padding: 0.125em 0.375em;
    border-radius: 4px;
  }

  pre {
    font-family: var(--font-mono);
    background: var(--code-bg);
    color: var(--code-text);
    padding: 1.25rem;
    border-radius: var(--radius);
    overflow-x: auto;
    line-height: 1.7;
  }

  pre code {
    background: none;
    padding: 0;
    font-size: 0.875rem;
  }

  .container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius);
    font-size: 0.9375rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: all 0.15s;
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
  }
  .btn-primary:hover {
    background: var(--accent-hover);
    color: #fff;
  }

  .btn-secondary {
    background: var(--bg-alt);
    color: var(--text);
    border: 1px solid var(--border);
  }
  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(8px);
  }

  .header-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text);
    font-weight: 700;
    font-size: 1.0625rem;
  }
  .logo:hover {
    color: var(--text);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.15s, background 0.15s;
  }
  .nav-link:hover {
    color: var(--text);
    background: var(--bg-alt);
  }
  .nav-link.active {
    color: var(--accent);
  }

  .lang-switch {
    margin-left: 0.5rem;
    padding: 0.25rem 0.625rem;
    font-size: 0.8125rem;
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 6px;
    border: none;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
  }
  .theme-btn:hover {
    color: var(--text);
    background: var(--bg-alt);
  }

  .icon-sun { display: block; }
  .icon-moon { display: none; }

  :root[data-theme="dark"] .icon-sun { display: none; }
  :root[data-theme="dark"] .icon-moon { display: block; }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .icon-sun { display: none; }
    :root:not([data-theme="light"]) .icon-moon { display: block; }
  }

  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--bg-alt);
    margin-top: auto;
  }

  .footer-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-brand .logo {
    font-size: 1rem;
  }

  .footer-tagline {
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-top: 0.375rem;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: var(--text-muted);
    font-size: 0.875rem;
  }
  .footer-links a:hover {
    color: var(--text);
  }

  .footer-copy {
    color: var(--text-muted);
    font-size: 0.8125rem;
  }
</style>
