---
interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const {
  title,
  description = 'PicFast — Open source, self-hosted image hosting with API-first design',
  lang = 'en',
} = Astro.props;

const currentPath = Astro.url.pathname;
const isDocs = currentPath.startsWith('/zh/docs') || currentPath.startsWith('/docs');
const locale = currentPath.startsWith('/zh') ? 'zh' : 'en';
const switchLocale = locale === 'en' ? '/zh' : '/';
const switchLocaleLabel = locale === 'en' ? '中文' : 'English';
const homeLink = locale === 'en' ? '/' : '/zh';
const docsLink = locale === 'en' ? '/docs/getting-started' : '/zh/docs/getting-started';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href={homeLink} class="logo">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <rect width="28" height="28" rx="6" fill="var(--accent)"/>
            <path d="M7 14L11.5 18.5L17 10L21 16L24 13" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="8" cy="10" r="2" fill="white"/>
          </svg>
          <span class="logo-text">PicFast</span>
        </a>
        <nav class="nav-links">
          <a href={docsLink} class:list={["nav-link", { active: isDocs }]}>
            {locale === 'en' ? 'Docs' : '文档'}
          </a>
          <a href="https://github.com/atbeta/picfast" class="nav-link" target="_blank" rel="noopener">
            GitHub
          </a>
          <a href={switchLocale} class="nav-link lang-switch">
            {switchLocaleLabel}
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <a href={homeLink} class="logo">
            <svg width="20" height="20" viewBox="0 0 28 28" fill="none">
              <rect width="28" height="28" rx="6" fill="var(--accent)"/>
              <path d="M7 14L11.5 18.5L17 10L21 16L24 13" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="8" cy="10" r="2" fill="white"/>
            </svg>
            <span>PicFast</span>
          </a>
          <p class="footer-tagline">
            {locale === 'en'
              ? 'Open source, self-hosted image hosting'
              : '开源、自托管的图片托管服务'}
          </p>
        </div>
        <div class="footer-links">
          <a href={docsLink}>
            {locale === 'en' ? 'Documentation' : '文档'}
          </a>
          <a href="https://github.com/atbeta/picfast" target="_blank" rel="noopener">GitHub</a>
          <a href={switchLocale}>{switchLocaleLabel}</a>
        </div>
        <p class="footer-copy">
          MIT License · {new Date().getFullYear()}
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #ffffff;
    --bg-alt: #f7f8fa;
    --text: #111827;
    --text-muted: #6b7280;
    --border: #e5e7eb;
    --accent: #2563eb;
    --accent-hover: #1d4ed8;
    --code-bg: #f3f4f6;
    --code-text: #111827;
    --radius: 8px;
    --font-sans: 'Inter', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0f1117;
      --bg-alt: #1a1d27;
      --text: #e5e7eb;
      --text-muted: #9ca3af;
      --border: #2d3140;
      --accent: #3b82f6;
      --accent-hover: #60a5fa;
      --code-bg: #1e2330;
      --code-text: #e5e7eb;
    }
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    -webkit-text-size-adjust: 100%;
  }

  body {
    font-family: var(--font-sans);
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }
  a:hover {
    color: var(--accent-hover);
  }

  img {
    max-width: 100%;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--code-bg);
    color: var(--code-text);
    padding: 0.125em 0.375em;
    border-radius: 4px;
  }

  pre {
    font-family: var(--font-mono);
    background: var(--code-bg);
    color: var(--code-text);
    padding: 1.25rem;
    border-radius: var(--radius);
    overflow-x: auto;
    line-height: 1.7;
  }

  pre code {
    background: none;
    padding: 0;
    font-size: 0.875rem;
  }

  .container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius);
    font-size: 0.9375rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: all 0.15s;
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
  }
  .btn-primary:hover {
    background: var(--accent-hover);
    color: #fff;
  }

  .btn-secondary {
    background: var(--bg-alt);
    color: var(--text);
    border: 1px solid var(--border);
  }
  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(8px);
  }

  .header-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text);
    font-weight: 700;
    font-size: 1.0625rem;
  }
  .logo:hover {
    color: var(--text);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.15s, background 0.15s;
  }
  .nav-link:hover {
    color: var(--text);
    background: var(--bg-alt);
  }
  .nav-link.active {
    color: var(--accent);
  }

  .lang-switch {
    margin-left: 0.5rem;
    padding: 0.25rem 0.625rem;
    font-size: 0.8125rem;
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--bg-alt);
    margin-top: auto;
  }

  .footer-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-brand .logo {
    font-size: 1rem;
  }

  .footer-tagline {
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-top: 0.375rem;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: var(--text-muted);
    font-size: 0.875rem;
  }
  .footer-links a:hover {
    color: var(--text);
  }

  .footer-copy {
    color: var(--text-muted);
    font-size: 0.8125rem;
  }
</style>
