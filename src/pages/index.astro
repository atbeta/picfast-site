---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="PicFast — Self-hosted Image Hosting">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-badge">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M2 7L5.5 10.5L12 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Open Source · MIT License
      </div>
      <h1>Your images.<br />Your server.<br />Your control.</h1>
      <p class="hero-sub">
        Deploy a full-featured image hosting service in minutes.
        No tracking, no limits, no third-party dependency.
      </p>
      <div class="hero-code">
        <div class="code-label">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
          <span class="code-filename">terminal</span>
        </div>
        <pre><code><span class="prompt">$</span> docker run -d -p 8080:8080 \
  -v ./data:/data \
  picfast/picfast</code></pre>
        <button class="copy-btn" data-copy="docker run -d -p 8080:8080 -v ./data:/data picfast/picfast">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <rect x="4" y="4" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
            <path d="M2 10V3a1 1 0 011-1h7" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
          </svg>
          Copy
        </button>
      </div>
      <div class="hero-actions">
        <a href="/docs/getting-started" class="btn btn-primary">Get Started</a>
        <a href="https://github.com/atbeta/picfast" class="btn btn-secondary" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          View on GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <div class="container">
      <h2 class="section-title">Everything you need, nothing you don't</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <rect x="2" y="4" width="18" height="14" rx="2.5" stroke="currentColor" stroke-width="1.75"/>
              <path d="M2 8l6 4 4-3 8 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="7" cy="7" r="1.5" fill="currentColor"/>
            </svg>
          </div>
          <h3>API-First Design</h3>
          <p>
            Clean REST API with OpenAPI spec. Upload via curl, ShareX, or any HTTP client.
            Integrate with your existing workflow — no vendor lock-in.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M11 2L3 6v6c0 5.25 3.4 10.15 8 11.4 4.6-1.25 8-6.15 8-11.4V6L11 2z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M8 11l2 2 4-4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Privacy by Default</h3>
          <p>
            No tracking, no analytics, no ads. Your images stay on your server.
            Optional content moderation — you control what gets hosted.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M4 4h14v14H4z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
              <path d="M4 8h14M8 8v10" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Multiple Storage Backends</h3>
          <p>
            Local filesystem, S3, OSS, COS, Kodo, or WebDAV.
            Switch storage backends without re-uploading existing images.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M4 12h14M4 6h14M4 18h14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Developer Experience</h3>
          <p>
            OpenAPI documentation with live testing, ShareX support,
            multi-format link output (URL, Markdown, BBCode, HTML).
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M11 3v4M11 15v4M3 11H7M15 11h4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
              <circle cx="11" cy="11" r="3" stroke="currentColor" stroke-width="1.75"/>
            </svg>
          </div>
          <h3>Extensible</h3>
          <p>
            Group-based permission system, configurable upload limits,
            image processing (compression, watermarking, thumbnail generation).
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <rect x="3" y="3" width="16" height="16" rx="3" stroke="currentColor" stroke-width="1.75"/>
              <path d="M7 11h8M7 7h8M7 15h5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Modern Stack</h3>
          <p>
            Built with Go and React. Single binary deployment.
            PostgreSQL for persistence, no external service dependencies.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison -->
  <section class="comparison">
    <div class="container">
      <h2 class="section-title">How it compares</h2>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th></th>
              <th>Chevereto</th>
              <th>Photoview</th>
              <th>Self-built S3</th>
              <th>PicFast</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Setup time</td>
              <td>~30 min</td>
              <td>~20 min</td>
              <td>~2 hours</td>
              <td><strong>~5 min</strong></td>
            </tr>
            <tr>
              <td>API support</td>
              <td>Basic</td>
              <td>Limited</td>
              <td>Custom</td>
              <td><strong>OpenAPI + docs</strong></td>
            </tr>
            <tr>
              <td>ShareX integration</td>
              <td>✅</td>
              <td>❌</td>
              <td>Custom</td>
              <td><strong>✅ Built-in</strong></td>
            </tr>
            <tr>
              <td>Storage backends</td>
              <td>Limited</td>
              <td>Local only</td>
              <td>S3 only</td>
              <td><strong>6 backends</strong></td>
            </tr>
            <tr>
              <td>Content moderation</td>
              <td>❌</td>
              <td>❌</td>
              <td>Custom</td>
              <td><strong>✅ Built-in</strong></td>
            </tr>
            <tr>
              <td>Thumbnail generation</td>
              <td>✅</td>
              <td>✅</td>
              <td>Custom</td>
              <td><strong>✅ Auto</strong></td>
            </tr>
            <tr>
              <td>Image processing</td>
              <td>Basic</td>
              <td>Limited</td>
              <td>Custom</td>
              <td><strong>✅ Compression + watermark</strong></td>
            </tr>
            <tr>
              <td>Open source</td>
              <td>Paid</td>
              <td>✅</td>
              <td>N/A</td>
              <td><strong>✅ MIT</strong></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Quick Start -->
  <section class="quick-start">
    <div class="container">
      <h2 class="section-title">Quick start</h2>
      <div class="quick-start-grid">
        <div class="qs-step">
          <div class="qs-num">1</div>
          <div class="qs-content">
            <h3>Pull the image</h3>
            <p>One command to get started. Data persists in a local volume.</p>
            <div class="hero-code small">
              <pre><code>docker run -d -p 8080:8080 \
  -v $(pwd)/data:/data \
  picfast/picfast</code></pre>
            </div>
          </div>
        </div>
        <div class="qs-step">
          <div class="qs-num">2</div>
          <div class="qs-content">
            <h3>Configure</h3>
            <p>Edit <code>config.yaml</code> to set your domain, storage, and admin credentials.</p>
            <div class="hero-code small">
              <pre><code>cp config.example.yaml config.yaml
$EDITOR config.yaml</code></pre>
            </div>
          </div>
        </div>
        <div class="qs-step">
          <div class="qs-num">3</div>
          <div class="qs-content">
            <h3>Upload via API</h3>
            <p>Upload your first image with a simple curl command.</p>
            <div class="hero-code small">
              <pre><code>curl -X POST http://localhost:8080/api/v1/upload \
  -H "Authorization: Bearer YOUR_TOKEN" \
  -F "file=@image.png"</code></pre>
            </div>
          </div>
        </div>
      </div>
      <p class="qs-cta">
        <a href="/docs/getting-started" class="btn btn-primary">Full documentation →</a>
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = btn.getAttribute('data-copy') || '';
      navigator.clipboard.writeText(text).then(() => {
        const original = btn.innerHTML;
        btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3 3 7-7" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg> Copied`;
        setTimeout(() => { btn.innerHTML = original; }, 2000);
      });
    });
  });
</script>

<style>
  /* Hero */
  .hero {
    padding: 5rem 0 4rem;
    text-align: center;
  }

  .hero .container {
    max-width: 720px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.3125rem 0.75rem;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  h1 {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-size: 1.125rem;
    color: var(--text-muted);
    max-width: 540px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .hero-code {
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-align: left;
    margin-bottom: 1.75rem;
    overflow: hidden;
  }

  .code-label {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--border);
    background: var(--code-bg);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot.red { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green { background: #28c840; }

  .code-filename {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-left: 0.375rem;
  }

  .hero-code pre {
    padding: 1.25rem 1.25rem 1.25rem 1.25rem;
    margin: 0;
    background: transparent;
    border-radius: 0;
    font-size: 0.875rem;
    overflow-x: auto;
  }

  .hero-code .prompt {
    color: var(--accent);
    margin-right: 0.5rem;
    user-select: none;
  }

  .copy-btn {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.25rem 0.625rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    transition: all 0.15s;
  }
  .copy-btn:hover {
    color: var(--text);
    border-color: var(--text-muted);
  }

  .hero-code {
    position: relative;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* Features */
  .features {
    padding: 5rem 0;
    background: var(--bg-alt);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 3rem;
    letter-spacing: -0.02em;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 900px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .features-grid { grid-template-columns: 1fr; }
  }

  .feature-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
  }

  .feature-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: 8px;
    margin-bottom: 1rem;
    color: var(--accent);
  }

  .feature-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .feature-card p {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* Comparison */
  .comparison {
    padding: 5rem 0;
  }

  .table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
    min-width: 640px;
  }

  th, td {
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  th {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--text-muted);
    background: var(--bg-alt);
  }

  th:last-child,
  td:last-child {
    background: var(--bg-alt);
  }

  tbody tr:hover {
    background: var(--bg-alt);
  }

  td:first-child {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  /* Quick Start */
  .quick-start {
    padding: 5rem 0;
    background: var(--bg-alt);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .quick-start-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 680px;
    margin: 0 auto;
  }

  .qs-step {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .qs-num {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    background: var(--accent);
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 700;
    margin-top: 0.25rem;
  }

  .qs-content h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.375rem;
  }

  .qs-content p {
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .hero-code.small pre {
    font-size: 0.8125rem;
    padding: 1rem;
  }

  .qs-cta {
    text-align: center;
    margin-top: 2.5rem;
  }
</style>
